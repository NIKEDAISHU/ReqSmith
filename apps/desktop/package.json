{
  "name": "reqsmith",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "main": "./dist/main/index.js",
  "description": "ReqSmith — Scan. Shape. Test. A local-first API testing workbench.",
  "author": "ReqSmith",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p src/renderer/tsconfig.json && vite build",
    "build:main": "tsc -p src/main/tsconfig.json",
    "build:preload": "tsc -p src/preload/tsconfig.json",
    "build:engine": "tsc -p src/engine/tsconfig.json",
    "build:all": "npm run build:main && npm run build:preload && npm run build:engine && npm run build",
    "electron:dev": "node scripts/dev.js",
    "electron:build": "npm run build:all && electron-builder --win",
    "pack": "npm run build:all && electron-builder --win --dir",
    "dist": "npm run build:all && electron-builder --win"
  },
  "dependencies": {
    "@reqsmith/contracts": "workspace:*",
    "@reqsmith/data-generator": "workspace:*",
    "@reqsmith/design-system": "workspace:*",
    "@reqsmith/domain": "workspace:*",
    "@reqsmith/persistence": "workspace:*",
    "@reqsmith/scanner-spring": "workspace:*",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.8.9",
    "kysely": "^0.28.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "zustand": "^5.0.0"
  },
  "build": {
    "appId": "com.reqsmith.desktop",
    "productName": "ReqSmith",
    "copyright": "Copyright © 2025 ReqSmith",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [],
    "publish": {
      "provider": "github",
      "owner": "NIKEDAISHU",
      "repo": "ReqSmith"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": null,
      "uninstallerIcon": null,
      "installerHeaderIcon": null,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ReqSmith"
    },
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "**/better-sqlite3/**"
    ]
  }
}
